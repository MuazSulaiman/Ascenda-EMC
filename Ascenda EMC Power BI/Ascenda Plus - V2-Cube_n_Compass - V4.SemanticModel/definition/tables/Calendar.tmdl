	partition Calendar = calculated
		mode: import
		source = ```
				
				ADDCOLUMNS (
				    CALENDAR ( DATE(2022,1,1), TODAY() ),
				    "Year", YEAR([Date]),
				    "Month", FORMAT([Date], "MMM"),
				    "MonthNumber", MONTH([Date]),
				    "WeekdayName", FORMAT([Date], "ddd"),
				    "WeekdayNumber", WEEKDAY([Date],1)
				)
				
				```

