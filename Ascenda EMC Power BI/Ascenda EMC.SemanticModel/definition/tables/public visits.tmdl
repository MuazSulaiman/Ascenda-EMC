	column AfterHours_Home_OR =
			
			VAR Obj = 'public visits'[objective_id]
			VAR IsWantedObjective =
			    Obj IN { 494, 496, 616, 619 }   -- Home Visit + OR Technical Support + TS OR Avanos + TS Home Visit (replace IDs if needed)
			
			VAR dt  = 'public visits'[Date Local]
			VAR Dow = WEEKDAY(dt, 1)          -- 1 = Sunday, 7 = Saturday
			VAR Hr  = HOUR(dt)
			
			VAR IsWeekday  = Dow >= 1 && Dow <= 5   -- Sun–Thu
			VAR IsWeekend  = Dow >= 6               -- Fri–Sat
			
			VAR IsWeekdayOvertime =
			    IsWeekday && (Hr >= 17 || Hr < 8)   -- after 5 PM or before 8 AM
			
			VAR IsWeekendOvertime =
			    IsWeekend                           -- whole weekend = overtime
			
			RETURN
			IF(
			    NOT IsWantedObjective,
			    BLANK(),                            -- all other objectives ignored
			    IF(
			        IsWeekdayOvertime || IsWeekendOvertime,
			        "Overtime",
			        "Working Hours"
			    )
			)
		isHidden
		lineageTag: c04e9f22-0ce1-4533-b72e-1e97e5695937
		summarizeBy: none

		changedProperty = IsHidden

		annotation SummarizationSetBy = Automatic

