table 'public visits'
	isHidden
	lineageTag: e7e5a1e0-0901-466d-8fd0-59662344bbbe

	measure 'Last Refreshed' = ```
			
			"Last Refresh: " & FORMAT(NOW(), "dd/MM/yyyy hh:mm:ss AM/PM")
			
			```
		isHidden
		lineageTag: fe9fe69c-3b09-4628-9513-73b0c5b2ae8f

		changedProperty = IsHidden

	measure 'Departments Visited' =
			
			CALCULATE(
			    DISTINCTCOUNT('public target_audiences'[Department]),
			    TREATAS(
			        VALUES('public visits'[Audience]),
			        'public target_audiences'[Audience ID]
			    )
			)
		formatString: 0
		isHidden
		lineageTag: ab4b9db5-dcd4-4144-9768-798942c34102

		changedProperty = IsHidden

	measure 'Customers Visited per Working Day' =
			
			AVERAGEX (
			    FILTER (
			        VALUES ( 'public visits'[Visit Date] ),
			        WEEKDAY ( 'public visits'[Visit Date], 1 ) >= 1
			            && WEEKDAY ( 'public visits'[Visit Date], 1 ) <= 5   -- Sun to Thu
			    ),
			    CALCULATE (
			        DISTINCTCOUNT ( 'public visits'[customer_id] )
			    )
			)
		formatString: #,0.0
		isHidden
		lineageTag: 8fa7832d-b0f5-4dab-b7ba-2c1dd613f39b

		changedProperty = IsHidden

	measure 'Visits by Customer' =
			
			DIVIDE(
				COUNTA('public visits'[Visit #]),
				DISTINCTCOUNT('public visits'[customer_id])
			)
		formatString: #,0.0
		isHidden
		lineageTag: 2796ec3c-fbd1-4d1d-bb73-a2b3fc5a4038

		extendedProperty MeasureTemplate =
				{
				  "version": 0,
				  "daxTemplateName": "MathematicalDivision"
				}

		changedProperty = FormatString

		changedProperty = IsHidden

	measure 'Audience by Customer' =
			
			DIVIDE(
				DISTINCTCOUNT('public visits'[Audience]),
				DISTINCTCOUNT('public visits'[customer_id])
			)
		formatString: #,0.0
		isHidden
		lineageTag: a03c5e00-4556-4ce2-af3e-c63a7a0daf68

		changedProperty = IsHidden

	measure 'Avg Customers Visited per Month' = ```
			
			AVERAGEX (
			    VALUES ( 'public visits'[MonthStart] ),
			    CALCULATE ( DISTINCTCOUNT ( 'public visits'[customer_id] ) )
			)
			
			```
		formatString: #,0.0
		isHidden
		lineageTag: b7b6ac3f-9369-456e-a02a-f9d02034067c

		changedProperty = IsHidden

	measure 'Avg Business Lines Visited per Month' = ```
			
			AVERAGEX (
			    VALUES ( 'public visits'[MonthStart] ),
			    CALCULATE ( DISTINCTCOUNT ( 'public visits'[business_line_id] ) )
			)
			
			```
		formatString: #,0.0
		isHidden
		lineageTag: 2e39bf4a-6f19-458c-847f-dc91f84187bf

		changedProperty = IsHidden

